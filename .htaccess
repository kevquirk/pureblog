RewriteEngine On

# Disable directory listing
Options -Indexes

# Block hidden files (starting with .)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block sensitive directories
RewriteRule ^(?:config|data|backup)(?:/|$) - [F,L]

# Block sensitive files
RewriteRule (^|/)(?:VERSION|.*\.md)$ - [F,L]

# Block .git directory access
RewriteRule (^|/)\.git(?:/|$) - [F,L]

# Redirect sitemap.xml to sitemap.php
RewriteRule ^sitemap\.xml$ sitemap.php [L,QSA]

# Allow direct access to existing files and folders
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Everything else goes through the front controller
RewriteRule ^ index.php [L,QSA]
